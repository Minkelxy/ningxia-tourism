{
	admin off
	auto_https off
}

:8888 {
	handle_path /ningxia/* {
		root * /home/minke/ningxia-tourism/dist
		encode gzip

		# 数据文件直接服务
		handle /data/* {
			file_server
		}

		# 静态资源文件直接服务
		handle /assets/* {
			file_server
		}

		# 其他请求使用 try_files 支持 SPA
		handle {
			file_server
			try_files {path} {path}/ /index.html
		}
	}

	log {
		output stdout
		format json
	}
}
